# Epic Games API credentials (Fortnite PC client)
EPIC_CLIENT_ID=your_client_id_here
EPIC_CLIENT_SECRET=your_client_secret_here

# Your Epic Games display name (used by get_data.py to resolve account ID)
EPIC_DISPLAY_NAME=Your Display Name

# Refresh token (obtained via epic_login.ps1, rotates on each use)
# EPIC_REFRESH_TOKEN=
